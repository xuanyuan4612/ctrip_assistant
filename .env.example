# ========================================
# 携程 AI 助手 - 环境变量模板
# 复制此文件为 .env 并填入真实值
# ========================================

# 应用
APP_NAME=ctrip_assistant
DEBUG=false
HOST=0.0.0.0
PORT=8000

# 数据库 (MySQL 业务数据)
DATABASE_URL=mysql+aiomysql://user:password@localhost:3306/ctrip_assistant

# 数据库 (PostgreSQL - Agent 记忆, Phase 4 启用)
PG_DATABASE_URL=postgresql+asyncpg://langgraph:password@localhost:5432/langgraph

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT (生成方式: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=<generate-random-64-char-hex>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:8080"]

# LLM - OpenAI
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_API_KEY=sk-...
LLM_API_BASE=https://api.openai.com/v1
LLM_TEMPERATURE=0.8
LLM_MAX_RETRIES=3
LLM_TIMEOUT=60

# LLM - DeepSeek (备选)
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-chat
# LLM_API_KEY=sk-...
# LLM_API_BASE=https://api.deepseek.com/v1

# Embedding
EMBEDDING_API_KEY=sk-...
EMBEDDING_API_BASE=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# Qdrant (向量存储, Phase 4 启用)
QDRANT_URL=http://localhost:6333

# 速率限制
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_GLOBAL=100/minute

# 白名单 (跳过 JWT 认证的路径)
AUTH_WHITELIST=["/api/v1/auth/login","/api/v1/auth/register","/api/v1/health","/docs","/openapi.json"]

# 日志
LOG_LEVEL=INFO
LOG_FORMAT=json
